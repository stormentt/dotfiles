[colors]
black = #1a1a1a
gray = #a5a5a5
silver = #c4c4c4
white = #fcfcfc
red = #e54b4b
pink = #f1b7c4
green = #88fc82
yellow = #e8ff7f
blue = #677fea
purple = #b872ea
teal = #5ff4ef
orange = #fcd467

[module/date]
type = internal/date
interval = 1.0
date = %Y-%m-%d
time = %I:%M:%S
label = %{F#5ff4ef}%date% %{F-} %time%
label-font = 1

[module/volume]
type = internal/volume

master-soundcard = default
headphone-soundcard = default

master-mixer = Master
headphone-mixer = Headphone
headphone-id = 17

mapped = true

format-volume = <label-volume>
label-volume = %percentage%%

[module/mpd]
type = internal/mpd
host = 127.0.0.1
port = 6600

interval = 2

format-online = %{u#b872ea} <icon-prev> %{u#88fc82} <toggle> <label-song> %{u#b872ea} <icon-next> %{u-}
format-playing = %{u#b872ea} <icon-prev> %{u#88fc82} <toggle> <label-song> %{u#b872ea} <icon-next> %{u-}
format-paused = %{u#b872ea} <icon-prev> %{u#e8ff7f} <toggle> <label-song> %{u#b872ea} <icon-next> %{u-}
format-stopped = 

label-song-font = 5
label-song = %artist% - %title%
icon-play = 
icon-pause = 
icon-prev = 
icon-next = 

label-song-click-left = mpc pause

[module/mail]
type = custom/script
interval = 30
format = <label>
exec = ~/.config/polybar/mail
format-padding = 2

[module/wireless]
type = internal/network
interface = wlp3s0
interval = 3.0
accumulate-stats = true
format-connected = <ramp-signal> <label-connected>
format-disconnected = <label-disconnected>
format-packetloss = <label-connected>

label-connected = %local_ip% %downspeed% %upspeed%
label-connected-foreground = ${colors.green}

label-disconnected = %ifname%
label-disconnected-foreground = ${colors.red}

ramp-signal-0 = 
ramp-signal-1 = 
ramp-signal-2 = 
ramp-signal-3 = 
ramp-signal-4 = 
ramp-signal-5 = 

ramp-signal-0-foreground = ${colors.red}
ramp-signal-1-foreground = ${colors.red}
ramp-signal-2-foreground = ${colors.yellow}
ramp-signal-3-foreground = ${colors.yellow}
ramp-signal-4-foreground = ${colors.green}
ramp-signal-5-foreground = ${colors.green}

[module/memory]
type = internal/memory
format = <bar-used>
bar-used-indicator =
bar-used-width = 10
bar-used-foreground-0 = ${colors.green}
bar-used-foreground-1 = ${colors.green}
bar-used-foreground-2 = ${colors.yellow}
bar-used-foreground-3 = ${colors.red}
bar-used-fill = ▐
bar-used-empty = ▐
bar-used-empty-foreground = ${colors.gray}

[module/cpu]
type = internal/cpu
interval = 0.5
format = <ramp-coreload>
format-font = 2
ramp-coreload-0 = ▁
ramp-coreload-1 = ▂
ramp-coreload-2 = ▃
ramp-coreload-3 = ▄
ramp-coreload-4 = ▅
ramp-coreload-5 = ▆
ramp-coreload-6 = ▇
ramp-coreload-7 = █

ramp-coreload-0-foreground = ${colors.green}
ramp-coreload-1-foreground = ${colors.green}
ramp-coreload-2-foreground = ${colors.yellow}
ramp-coreload-3-foreground = ${colors.yellow}
ramp-coreload-4-foreground = ${colors.yellow}
ramp-coreload-5-foreground = ${colors.red}
ramp-coreload-6-foreground = ${colors.red}
ramp-coreload-7-foreground = ${colors.red}

[section/fs]
type = internal/fs

fixed-values = true
format-mounted = <label-mounted> <bar-used>
label-mounted-font = 3

bar-used-indicator = 
bar-used-width = 7
bar-used-fill-foreground = ${colors.blue}
bar-used-fill = ▐
bar-used-empty = ▐
bar-used-empty-foreground = ${colors.gray}

[module/fs-root]
inherit = section/fs
mount-0 = /
label-mounted = 
label-mounted-underline = ${colors.purple}

[module/fs-home]
inherit = section/fs
mount-0 = /home
label-mounted = 
label-mounted-underline = ${colors.purple}

[module/i3]
type = internal/i3
strip-wsnumbers = true

ws-icon-0 = "1:Browser;"
ws-icon-1 = "2:Smartwarn;"
ws-icon-2 = "3:VirtualBox;"
ws-icon-3 = "4:Music;"
ws-icon-4 = "5:General Left;"
ws-icon-5 = "6:General Right;"
ws-icon-6 = "7:Programming;"
ws-icon-7 = "8:SSH;"
ws-icon-8 = "9:Logs;"
ws-icon-9 = "10:Monitoring;"

label-mode-padding = 2
label-visible-padding = 2

label-focused = %icon%  %name%
label-focused-background = ${colors.white}
label-focused-foreground = ${colors.black}
label-focused-underline = ${colors.blue}
label-focused-padding = 2

label-unfocused = %icon%  %name%
label-unfocused-padding = 2

label-urgent = %icon%  %name%
label-urgent-padding = 2
label-urgent-underline = ${colors.red}


[bar/top]
monitor = ${env:MONITOR:}
bottom = false
background = ${colors.black}
foreground = ${colors.white}
padding = 2
module-margin = 1
modules-right = date
modules-center = wireless
modules-left = i3
tray-position = right
font-0 = Roboto:size=12;-2
font-1 = FontAwesome:size=13;-2
font-2 = FontAwesome:size=12;-2
font-3 = MaterialIcons:size=16;-2
font-4 = FontAwesome:size=14;-2
underline-size = 2

[bar/bottom]
monitor = ${env:MONITOR:}
bottom = true
background = ${colors.black}
foreground = ${colors.white}
padding = 2
module-margin = 2
font-0 = Roboto Mono:style=Light:size=12;-4
font-1 = FontAwesome:size=10;-3
font-2 = FontAwesome:size=12;-3
font-3 = MaterialIcons:size=16;-7
font-4 = Inconsolata:size=11;-3
underline-size = 2
modules-right = fs-root
modules-left = cpu memory
modules-center = mpd
